# ── 共用資料庫設定範本 ──────────────────────────────────
# 用法：把這個檔複製成 .env（放在專案根目錄，與此檔同層），再填入實際值。
# .env 已被 .gitignore 忽略，不會上傳，請由負責人把填好的內容私下分享給組員。
#
#   Windows PowerShell:  Copy-Item .env.example .env
#   Mac / Linux:         cp .env.example .env
# ────────────────────────────────────────────────────────

# 共用雲端 MySQL 連線資訊（向 Railway / Aiven / Zeabur 等平台申請後填入）
DB_NAME=course_platform_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=3306

# 只有平台要求 TLS 時才填（例如 Aiven 會給一個 ca.pem，填它的完整路徑）
# DB_SSL_CA=C:\path\to\ca.pem

# 開發時維持 True；正式部署再改 False
DEBUG=True

# 正式部署時建議換成自己的隨機字串；本機開發可留空使用預設
# SECRET_KEY=
